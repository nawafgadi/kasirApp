<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.KasirPAS" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.KasirPAS" parent="Base.Theme.KasirPAS" />

    <!-- Style untuk Bottom Navigation tanpa indikator bermasalah -->
    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/primary</item>
        <item name="itemTextColor">@color/primary</item>
        <item name="backgroundTint">@color/white</item>
        <!-- Kita matikan indikator bawaan Material 3 yang hitam itu -->
        <item name="itemActiveIndicatorStyle">@null</item>
    </style>
</resources>