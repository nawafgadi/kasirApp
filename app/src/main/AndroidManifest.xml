<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KasirPAS"
        android:usesCleartextTraffic="true"
        tools:targetApi="35">

        <!-- Entry Point: SplashActivity -->
        <activity
            android:name=".activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KasirPAS">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Dashboard -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Auth & Onboarding (Compose) -->
        <activity
            android:name=".activity.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".activity.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".activity.OnboardingActivity"
            android:exported="false" />

        <!-- Management & Features -->
        <activity
            android:name=".activity.HistoryActivity"
            android:exported="false"
            android:label="@string/title_activity_history" />
        <activity
            android:name=".activity.KelolaProductActivity"
            android:exported="false" />
        <activity
            android:name=".activity.KelolaKategoriActivity"
            android:exported="false" />
        <activity
            android:name=".activity.BillingActivity"
            android:exported="false" />

        <!-- AI Features -->
        <activity
            android:name=".activity.AiStocksActivity"
            android:exported="false" />
        <activity
            android:name=".activity.AiBussyHoursActivity"
            android:exported="false" />

    </application>

</manifest>
